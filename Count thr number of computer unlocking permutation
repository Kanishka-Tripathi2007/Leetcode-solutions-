#include <bits/stdc++.h>
using namespace std;

class Solution {
public:
    static const long long MOD = 1e9 + 7;

    int countPermutations(vector<int>& complexity) {

        int n = complexity.size();

        // validation step
        int prefixMin = complexity[0];

        for(int i = 1; i < n; i++) {
            if(complexity[i] <= prefixMin)
                return 0;   // cannot unlock

            prefixMin = min(prefixMin, complexity[i]);
        }

        // compute (n-1)!
        long long ans = 1;
        for(long long i = 2; i <= n - 1; i++)
            ans = (ans * i) % MOD;

        return ans;
    }
};
