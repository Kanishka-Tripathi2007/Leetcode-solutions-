#include <bits/stdc++.h>
using namespace std;

class Solution {
public:

    // Sieve to find primes
    vector<bool> sieve(int maxVal) {
        vector<bool> isPrime(maxVal + 1, true);
        isPrime[0] = isPrime[1] = false;

        for (int i = 2; i * i <= maxVal; i++) {
            if (isPrime[i]) {
                for (int j = i * i; j <= maxVal; j += i)
                    isPrime[j] = false;
            }
        }
        return isPrime;
    }

    // Get unique prime factors
    vector<int> primeFactors(int x) {
        vector<int> factors;
        for (int p = 2; p * p <= x; p++) {
            if (x % p == 0) {
                factors.push_back(p);
                while (x % p == 0) x /= p;
            }
        }
        if (x > 1) factors.push_back(x);
        return factors;
    }

    int minJumps(vector<int>& nums) {

        int n = nums.size();
        if (n == 1) return 0;

        int maxVal = *max_element(nums.begin(), nums.end());
        vector<bool> isPrime = sieve(maxVal);

        // prime -> indices divisible by that prime
        unordered_map<int, vector<int>> mp;

        for (int i = 0; i < n; i++) {
            vector<int> factors = primeFactors(nums[i]);
            for (int p : factors)
                mp[p].push_back(i);
        }

        queue<int> q;
        vector<bool> visited(n, false);

        q.push(0);
        visited[0] = true;

        int steps = 0;

        while (!q.empty()) {
            int sz = q.size();

            while (sz--) {
                int i = q.front();
                q.pop();

                if (i == n - 1) return steps;

                // adjacent moves
                if (i + 1 < n && !visited[i + 1]) {
                    visited[i + 1] = true;
                    q.push(i + 1);
                }

                if (i - 1 >= 0 && !visited[i - 1]) {
                    visited[i - 1] = true;
                    q.push(i - 1);
                }

                // prime teleport
                int val = nums[i];
                if (isPrime[val] && mp.count(val)) {

                    for (int idx : mp[val]) {
                        if (!visited[idx]) {
                            visited[idx] = true;
                            q.push(idx);
                        }
                    }

                    // IMPORTANT optimization
                    mp.erase(val);
                }
            }

            steps++;
        }

        return -1;
    }
};
