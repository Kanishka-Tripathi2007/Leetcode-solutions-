class Solution {
public:
    int gcdOfOddEvenSums(int n) {
        long long sumOdd = 1LL * n * n;
        long long sumEven = 1LL * n * (n + 1);

        return gcd(sumOdd, sumEven);
    }

private:
    long long gcd(long long a, long long b) {
        while (b) {
            long long temp = b;
            b = a % b;
            a = temp;
        }
        return a;
    }
};
