#include <bits/stdc++.h>
using namespace std;

class Solution {
public:
    int maximumJumps(vector<int>& nums, int target) {
        int n = nums.size();

        // dp[i] = maximum jumps to reach index i
        vector<int> dp(n, -1);
        dp[0] = 0;

        for(int i = 0; i < n; i++) {
            if(dp[i] == -1) continue; // unreachable

            for(int j = i + 1; j < n; j++) {
                long long diff = (long long)nums[j] - nums[i];

                if(abs(diff) <= target) {
                    dp[j] = max(dp[j], dp[i] + 1);
                }
            }
        }

        return dp[n - 1];
    }
};
